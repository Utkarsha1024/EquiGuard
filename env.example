# ─────────────────────────────────────────────────────────────────
# EquiGuard — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below (especially EQUIGUARD_API_KEY)
#   3. NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── API Security ──────────────────────────────────────────────────
# Strong random secret — generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
EQUIGUARD_API_KEY=replace-this-with-a-strong-secret-key

# ── Environment ───────────────────────────────────────────────────
# Options: development | production
ENV=development

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///equiguard.db
# Directory where equiguard.db is stored.
# Docker sets this to /app/data (the db_data volume mount) automatically.
# Leave unset for local dev — db.py will default to the project root.
# DATA_DIR=/app/data
# Full override path (takes precedence over DATA_DIR):
# DATABASE_PATH=/app/data/equiguard.db

# ── Server ────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Frontend → Backend URL ────────────────────────────────────────
# Used by Streamlit to know where the FastAPI backend lives.
# Change to your deployed URL in production.
API_BASE_URL=http://127.0.0.1:8000

# ── Gemini API (Audit Agent + Risk Narrative) ────────────────────
# Powers the conversational audit agent and Gemini Risk Narrative.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google Cloud Platform (Vision AI + Vertex AI) ─────────────────
# Required for the Visual Bias Scanner and Vertex AI Remediation Agent.
# Setup guide:
#   1. console.cloud.google.com → Enable Cloud Vision API + Vertex AI API
#   2. IAM → Service Accounts → Create → roles: Vertex AI User, Vision API User
#   3. Download JSON key → save as gcp-credentials.json in project root
#   4. Add gcp-credentials.json to .gitignore
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ── Webhook Alerting (Slack-compatible) ───────────────────────────────────────
# When WEBHOOK_ENABLED=true, EquiGuard POSTs a Slack-compatible alert payload
# to WEBHOOK_URL every time a compliance audit returns a FAIL result.
# Use a Slack Incoming Webhook URL, or any HTTP endpoint that accepts POST JSON.
# Leave WEBHOOK_ENABLED=false (or unset) to disable alerting entirely.
WEBHOOK_ENABLED=false
WEBHOOK_URL=
